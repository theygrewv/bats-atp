{
  "lexicon": 1,
  "id": "app.skydrops.bats.session",
  "defs": {
    "main": {
      "type": "record",
      "description": "A B.A.T.S. game room or active lobby.",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["roomName", "hostDid", "status", "createdAt"],
        "properties": {
          "roomName": { 
            "type": "string", 
            "description": "The name of the lobby (e.g., 'The Belfry' or 'Doris's Den').",
            "maxGraphemes": 64 
          },
          "hostDid": { 
            "type": "string", 
            "format": "did",
            "description": "The DID of the player who started this room." 
          },
          "currentCzarDid": { 
            "type": "string", 
            "format": "did",
            "description": "The DID of the player currently judging the blobs." 
          },
          "status": { 
            "type": "string", 
            "knownValues": ["lobby", "playing", "finished"],
            "default": "lobby" 
          },
          "maxPlayers": { 
            "type": "integer", 
            "default": 10 
          },
          "createdAt": { 
            "type": "string", 
            "format": "datetime" 
          }
        }
      }
    }
  }
}